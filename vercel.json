{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/selbstcheck", "destination": "/selbstcheck.html" },
    { "source": "/bericht",     "destination": "/bericht.html"     },
    { "source": "/coldcall",    "destination": "/coldcall.html"    },
    { "source": "/handwerk",    "destination": "/handwerk.html"    },
    { "source": "/beauty",      "destination": "/beauty.html"      }
  ],
  "headers": [
    {
      "source": "/(.*\\.html|selbstcheck|bericht|coldcall|termin|datenschutz|impressum)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://yad.rocks" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "crons": []
}
